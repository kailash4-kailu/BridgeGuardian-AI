# BridgeGuardian AI — Environment Configuration Template
# Copy this file to .env and adjust variables for your environment.
# NEVER commit .env to git — it is in .gitignore.
# For Render: set env vars in the Render dashboard.
# For Vercel: set VITE_* vars in the Vercel dashboard (frontend only).

# ── Core App Settings ─────────────────────────────────────────────────────────
APP_ENV=production
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-a-strong-random-key
DATABASE_URL=sqlite:///./bridgeguardian.db
LOG_LEVEL=WARNING
CONFIG_PATH=config

# ── CORS Origins ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Add your Vercel deployment URL here:
# CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173

# ── Server Setup ──────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
# IMPORTANT: SQLite does NOT support concurrent writes.
# Keep GUNICORN_WORKERS=1 when using SQLite as the database.
# Only increase this value after migrating DATABASE_URL to PostgreSQL.
GUNICORN_WORKERS=1

# ── Configurable Storage Directories ─────────────────────────────────────────
MODELS_DIR=models
UPLOAD_DIR=backend/static/uploads
PROCESSED_DIR=backend/static/processed
REPORTS_DIR=backend/static/reports
LOGS_DIR=logs

# ── Feature Toggles & Limits ──────────────────────────────────────────────────
DEMO_MODE=true
# 10MB in bytes — keep in sync with nginx.conf client_max_body_size
MAX_UPLOAD_SIZE=10485760

# ── API / Frontend URLs (used by backend for self-reference) ──────────────────
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
