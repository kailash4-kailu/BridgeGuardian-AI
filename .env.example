# BridgeGuardian AI — Environment Configuration
# Copy this file to .env and adjust variables as needed

# Core App Settings
APP_ENV=production
SECRET_KEY=change-me-in-production-use-a-strong-random-key
DATABASE_URL=sqlite:///./bridgeguardian.db
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173
LOG_LEVEL=WARNING
CONFIG_PATH=config

# Server Setup
HOST=0.0.0.0
PORT=8000
GUNICORN_WORKERS=4

# Configurable Storage Directories (relative to backend folder or absolute paths)
MODELS_DIR=models
UPLOAD_DIR=backend/static/uploads
PROCESSED_DIR=backend/static/processed
REPORTS_DIR=backend/static/reports
LOGS_DIR=logs

# Feature Toggles & Limits
DEMO_MODE=true
MAX_UPLOAD_SIZE=10485760 # 10MB in bytes

# API / Frontend URLs
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost
