# BridgeGuardian AI — Frontend Production Environment Template
# Copy this to .env.production and fill in your values BEFORE deploying to Vercel.
# This file is safe to commit — it contains no secrets, only placeholders.
#
# Vercel will use these values at BUILD TIME (Vite bakes them into the JS bundle).
# Set them in the Vercel dashboard → Project → Settings → Environment Variables.

# ─── Backend API URL ──────────────────────────────────────────────────────────
# Set this to your Render backend service URL.
# Do NOT include a trailing slash.
# Example: https://bridgeguardian-backend.onrender.com
VITE_API_BASE_URL=https://YOUR-RENDER-BACKEND-URL.onrender.com

# ─── Notes ────────────────────────────────────────────────────────────────────
# For Docker Compose deployments (Nginx proxy): leave VITE_API_BASE_URL empty
# For local development: leave VITE_API_BASE_URL empty (Vite proxy handles /api)
